{
  "schema_version": "2.0",
  "skill_version": "5.0.0",
  "agent": "orchestrator-agent",
  "colony": "{{colony_name}}",
  "description": "Declarative O-Mode prompt router for the orchestrator-agent. Selection is deterministic — driven by trail state, cycle count, and EarnedConstraints.",
  "default": "system.prompt.md",
  "o_mode": {
    "optimize":    "o-mode-optimize.prompt.md",
    "output":      "o-mode-output.prompt.md",
    "orchestrate": "o-mode-orchestrate.prompt.md",
    "topology":    "o-mode-topology.prompt.md"
  },
  "selection_rules": {
    "cycle_1":                    "o-mode-optimize.prompt.md",
    "retry_cycle":                "o-mode-optimize.prompt.md",
    "final_cycle_before_maxloops":"o-mode-output.prompt.md",
    "conflict_detected":          "o-mode-orchestrate.prompt.md",
    "constraint_triggered":       "o-mode-orchestrate.prompt.md",
    "complex_intent":             "o-mode-topology.prompt.md",
    "multi_agent_intent":         "o-mode-topology.prompt.md",
    "graph_required":             "o-mode-topology.prompt.md",
    "default_fallback":           "system.prompt.md"
  },
  "selection_priority": [
    "constraint_triggered",
    "conflict_detected",
    "final_cycle_before_maxloops",
    "multi_agent_intent",
    "complex_intent",
    "retry_cycle",
    "cycle_1",
    "default_fallback"
  ],
  "metadata": {
    "maf_version": "1.10.0",
    "updated": "2026-06-19",
    "notes": "Priority list is evaluated top-to-bottom. First matching condition wins."
  }
}
